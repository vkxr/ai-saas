# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ============================================================
# REDIS (Upstash)
# https://console.upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token-here"

# ============================================================
# AUTH
# Generate with: openssl rand -base64 32
# ============================================================
JWT_ACCESS_SECRET="your-super-secret-access-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ============================================================
# OPENROUTER (AI)
# Get your key at https://openrouter.ai/keys
# ============================================================
OPENROUTER_API_KEY="sk-or-v1-your-openrouter-key-here"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_SITE_NAME="NexusAI"

# ============================================================
# RAZORPAY
# Get keys at https://dashboard.razorpay.com/app/keys
# ============================================================
RAZORPAY_KEY_ID="rzp_test_your-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# Generate with: openssl rand -hex 32
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# Razorpay Plan IDs (create once in dashboard or via API)
RAZORPAY_PLAN_PRO_MONTHLY="plan_..."
RAZORPAY_PLAN_PRO_YEARLY="plan_..."
RAZORPAY_PLAN_ENTERPRISE_MONTHLY="plan_..."
RAZORPAY_PLAN_ENTERPRISE_YEARLY="plan_..."

# Public key (safe for client-side)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your-key-id"

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="NexusAI"
NODE_ENV="development"
